---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import GLBackground from "../components/GLBackground.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
   <div>
     <canvas class="cursor"></canvas>
    <GLBackground/>
    <main>
      <slot />
    </main>
    <Footer />
   <div>
  </body>
</html>
